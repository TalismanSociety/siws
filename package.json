{
  "name": "siws-monorepo",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "prepare": "husky install",
    "dev": "pnpm --parallel --filter @talismn/siws --filter siws-demo run dev",
    "dev:docs": "pnpm --filter siwsdocs-astro dev",
    "dev:all": "pnpm --parallel --filter @talismn/siws --filter siws-demo --filter siwsdocs-astro run dev",
    "build": "pnpm -r build",
    "build:lib": "pnpm --filter @talismn/siws build",
    "build:demo": "pnpm --filter siws-demo build",
    "build:docs": "pnpm --filter siws-demo build:docs",
    "test": "pnpm -r test",
    "lint": "biome check . --error-on-warnings",
    "format": "biome format --write .",
    "preview": "pnpm --filter siws-demo build && pnpm --filter siws-demo preview",
    "deploy": "pnpm --filter siws-demo deploy"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.0",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^8.0.0",
    "semantic-release": "^24.2.1"
  }
}
